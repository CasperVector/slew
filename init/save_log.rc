#!/bin/rc -e

fn rotate {
	if ([ `{stat -c '%s' $1/0} -lt $3 ]) return
	j=$2
	for (i in `{seq 0 $2 | tac}) if ([ ! -f $1/$i ]) {
		j=$i; break
	}
	for (i in `{seq 0 $j | tac}) if ([ -f $1/$i ]) {
		if ([ $i -ge $2 ]) { rm $1/$i } \
			else mv $1/$i $1/`{expr $i + 1 || true}
	}
}

for (f in @*) if ([ -f $f ]) {
	{ cat $f >> $1/0; rm $f; rotate $* } || exec cat
}
cat >> $1/0; rotate $*

